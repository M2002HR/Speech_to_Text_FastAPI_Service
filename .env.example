# -------- Global --------
APP_CONFIG_FILE=config/config.yml

# -------- App --------
APP_NAME=Tootak
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8030
APP_LOG_LEVEL=INFO
APP_REQUEST_TIMEOUT_SEC=300
APP_ENABLE_DOCS=true
APP_DOCS_URL=/docs
APP_REDOC_URL=/redoc
APP_OPENAPI_URL=/openapi.json
APP_RELOAD=true
HF_HUB_DISABLE_SYMLINKS_WARNING=1
HF_TOKEN=

# -------- Storage --------
STORAGE_RUNTIME_DIR=runtime
STORAGE_UPLOAD_DIR=runtime/uploads
STORAGE_OUTPUT_DIR=runtime/outputs
STORAGE_MODEL_DIR=runtime/models
STORAGE_CLEANUP_TEMP_AFTER_REQUEST=true
STORAGE_MAX_UPLOAD_MB=2048

# -------- Processing --------
PROCESSING_FFMPEG_BINARY=ffmpeg
PROCESSING_FFPROBE_BINARY=ffprobe
PROCESSING_AUDIO_CODEC=pcm_s16le
PROCESSING_AUDIO_SAMPLE_RATE=16000
PROCESSING_AUDIO_CHANNELS=1
PROCESSING_ALWAYS_EXTRACT_AUDIO=true
PROCESSING_EXTRACTED_AUDIO_FORMAT=wav
PROCESSING_PRESERVE_ORIGINAL_UPLOAD=false

# -------- Security/Admin --------
ADMIN_ENABLED=true
ADMIN_REQUIRE_AUTH=false
ADMIN_TOKEN=
ADMIN_HEADER_NAME=x-admin-token

# -------- Transcription --------
TRANSCRIPTION_DEFAULT_PROVIDER=local
TRANSCRIPTION_DEFAULT_LANGUAGE=
TRANSCRIPTION_DEFAULT_PROMPT=
TRANSCRIPTION_DEFAULT_RESPONSE_FORMAT=verbose_json
TRANSCRIPTION_ENABLE_WORD_TIMESTAMPS=true
TRANSCRIPTION_ENABLE_SEGMENT_TIMESTAMPS=true

# -------- Local backend --------
LOCAL_BACKEND=faster_whisper
LOCAL_MODEL_ID=large-v3
LOCAL_DEVICE=auto
LOCAL_COMPUTE_TYPE=auto
LOCAL_CPU_THREADS=4
LOCAL_NUM_WORKERS=1
LOCAL_VAD_FILTER=true
LOCAL_BEAM_SIZE=10
LOCAL_BEST_OF=10
LOCAL_PATIENCE=1.3
LOCAL_TEMPERATURE=0
LOCAL_CONDITION_ON_PREVIOUS_TEXT=true
LOCAL_INITIAL_PROMPT=
LOCAL_REPETITION_PENALTY=1.0
LOCAL_NO_REPEAT_NGRAM_SIZE=0
LOCAL_COMPRESSION_RATIO_THRESHOLD=2.4
LOCAL_LOG_PROB_THRESHOLD=-1.0
LOCAL_NO_SPEECH_THRESHOLD=0.6
LOCAL_PROMPT_RESET_ON_TEMPERATURE=0.5
LOCAL_HALLUCINATION_SILENCE_THRESHOLD=
LOCAL_MAX_NEW_TOKENS=
LOCAL_VAD_THRESHOLD=
LOCAL_VAD_NEG_THRESHOLD=
LOCAL_VAD_MIN_SPEECH_DURATION_MS=
LOCAL_VAD_MIN_SILENCE_DURATION_MS=
LOCAL_VAD_SPEECH_PAD_MS=
LOCAL_LONG_AUDIO_CHUNKING_ENABLED=true
LOCAL_LONG_AUDIO_CHUNK_MINUTES=10
LOCAL_LONG_AUDIO_OVERLAP_MINUTES=5
LOCAL_LONG_AUDIO_MIN_DURATION_MINUTES=10
LOCAL_CHUNK_MERGE_SIMILARITY_THRESHOLD=0.72
LOCAL_CHUNK_MERGE_MAX_WORD_OVERLAP=48
LOCAL_VOCABULARY_BIAS_ENABLED=false
LOCAL_VOCABULARY_BIAS_TEXT=

# -------- OpenAI-compatible Providers --------
PROVIDER_OPENAI_ENABLED=false
PROVIDER_OPENAI_BASE_URL=https://api.openai.com
PROVIDER_OPENAI_API_KEY=
PROVIDER_OPENAI_MODEL=whisper-1
PROVIDER_OPENAI_TRANSCRIPTIONS_PATH=/v1/audio/transcriptions
PROVIDER_OPENAI_TIMEOUT_SEC=300

PROVIDER_GROQ_ENABLED=false
PROVIDER_GROQ_BASE_URL=https://api.groq.com/openai
PROVIDER_GROQ_API_KEY=
PROVIDER_GROQ_MODEL=whisper-large-v3
PROVIDER_GROQ_TRANSCRIPTIONS_PATH=/v1/audio/transcriptions
PROVIDER_GROQ_TIMEOUT_SEC=300

PROVIDER_CUSTOM_ENABLED=false
PROVIDER_CUSTOM_BASE_URL=
PROVIDER_CUSTOM_API_KEY=
PROVIDER_CUSTOM_MODEL=
PROVIDER_CUSTOM_TRANSCRIPTIONS_PATH=/v1/audio/transcriptions
PROVIDER_CUSTOM_TIMEOUT_SEC=300
PROVIDER_CUSTOM_AUTH_HEADER=Authorization
PROVIDER_CUSTOM_AUTH_SCHEME=Bearer

# -------- Model Download/Hugging Face --------
MIRRORS_HUGGINGFACE_BASE=https://huggingface.co

DOWNLOADS_ENABLED=true
DOWNLOADS_MAX_CONCURRENT_JOBS=2
DOWNLOADS_CHUNK_SIZE=1048576
DOWNLOADS_TIMEOUT_SEC=1800
DOWNLOADS_ALLOW_RESUME=true
DOWNLOADS_ALLOWED_DOMAINS=huggingface.co

# -------- Remote Queue Worker (Bale Bot Integration) --------
QUEUE_SERVER_BASE_URL=http://80.71.149.190:4000
QUEUE_WORKER_TOKEN=
QUEUE_WORKER_ID=
QUEUE_POLL_INTERVAL_SEC=3
QUEUE_LEASE_SEC=1800
QUEUE_WORKER_LOG_LEVEL=INFO

LOCAL_STT_URL=http://127.0.0.1:8030/transcribe
LOCAL_STT_JOBS_URL=http://127.0.0.1:8030/transcribe/jobs
LOCAL_STT_PROVIDER=local
LOCAL_STT_MODEL=
LOCAL_STT_LANGUAGE=fa
LOCAL_STT_PROFILE=ultra
LOCAL_STT_CHUNK_MINUTES=10
LOCAL_STT_CHUNK_OVERLAP_MINUTES=5
LOCAL_STT_TIMEOUT_SEC=1800

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.gapgpt.app/v1
OPENAI_FALLBACK_BASE_URLS=
OPENAI_PROXY_URL=
OPENAI_ALLOW_PUBLIC_OPENAI_FALLBACK=false
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SEC=120
OPENAI_RETRY_ROUNDS=3
OPENAI_RETRY_BACKOFF_SEC=1.2
LLM_FAIL_OPEN=true

LLM_PROMPT_TEMPLATE=تو یک ویرایشگر حرفه‌ای متن ترنسکریپت هستی. متن خام گفتار را بدون خلاصه‌سازی، کامل و روان بازنویسی کن. غلط‌های تایپی را اصلاح کن، نویز و تکرار بی‌معنا را حذف کن، و خروجی را دقیقا در فرمت {format} برگردان. فقط خروجی نهایی را بده و هیچ توضیح اضافه ننویس.
LLM_PROMPT_TEMPLATE_STRICT=تو یک ویرایشگر حداقلی ترنسکریپت هستی. خلاصه‌سازی یا حذف محتوا ممنوع است. متن را تا حد ممکن نزدیک به نسخه خام نگه دار و فقط اصلاح‌های بدیهی املایی/نگارشی را انجام بده. خروجی را دقیقا در فرمت {format} برگردان و توضیح اضافه ننویس.
